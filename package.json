{
  "name": "opengate",
  "version": "0.1.0",
  "description": "Library-first API endpoint protection with tiering, rate limiting, and audit logging.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    ".",
    "packages/*"
  ],
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./fastify": {
      "types": "./dist/src/fastify.d.ts",
      "default": "./dist/src/fastify.js"
    },
    "./express": {
      "types": "./dist/src/express.d.ts",
      "default": "./dist/src/express.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "bin": {
    "opengate": "dist/src/cli.js"
  },
  "scripts": {
    "dev": "tsx examples/website/server.ts",
    "mock:dev": "tsx examples/mock-website/server.ts",
    "express:dev": "tsx examples/express-website/server.ts",
    "build:root": "tsc -p tsconfig.json",
    "build:packages": "npm run build -w @opengate/express -w @opengate/fastify",
    "build": "npm run build:root && npm run build:packages",
    "docs:build": "node scripts/build-docs.mjs",
    "start": "node dist/examples/website/server.js",
    "cli": "tsx src/cli.ts",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "example:dev": "tsx examples/website/server.ts",
    "release": "semantic-release"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/formbody": "^7.4.0",
    "better-sqlite3": "^11.5.0",
    "express": "^4.21.2",
    "fastify": "^4.26.2",
    "jose": "^5.9.6",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.3",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.3",
    "@types/node": "^20.11.30",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^2.1.8",
    "supertest": "^7.1.4",
    "semantic-release": "^24.2.1",
    "tsx": "^4.20.6",
    "typescript": "^5.4.5",
    "vitest": "^2.1.8"
  }
}
